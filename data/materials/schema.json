{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparent.tools/data/materials/schema.json",
  "title": "Materials Database",
  "description": "Schema for the transparent.tools material property database.",
  "type": "object",
  "required": ["sources", "property_registry", "materials"],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "object",
      "description": "Registry of data sources keyed by source_id.",
      "additionalProperties": {
        "$ref": "#/$defs/source_record"
      }
    },
    "property_registry": {
      "type": "object",
      "description": "Metadata for each property field.",
      "additionalProperties": {
        "$ref": "#/$defs/property_meta"
      }
    },
    "materials": {
      "type": "array",
      "description": "Array of material records.",
      "items": {
        "$ref": "#/$defs/material_record"
      }
    }
  },

  "$defs": {
    "source_record": {
      "type": "object",
      "required": ["citation", "type"],
      "additionalProperties": false,
      "properties": {
        "citation": { "type": "string", "description": "Full citation string." },
        "type": {
          "type": "string",
          "enum": ["textbook", "vendor_datasheet", "online_database", "standard", "handbook", "journal", "estimate"]
        },
        "year": { "type": "integer" },
        "url": { "type": "string", "format": "uri" }
      }
    },

    "property_meta": {
      "type": "object",
      "required": ["label", "group"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "unit": { "type": ["string", "null"] },
        "display_unit": { "type": ["string", "null"] },
        "display_multiplier": { "type": "number" },
        "symbol": { "type": "string" },
        "latex": { "type": "string" },
        "axis_scale": { "type": "string", "enum": ["log", "linear"] },
        "higher_is": { "type": "string", "enum": ["better", "worse", "neutral"] },
        "group": {
          "type": "string",
          "enum": ["mechanical", "thermal", "electrical", "economic", "environmental", "processability", "identity"]
        },
        "plottable": { "type": "boolean" },
        "common": { "type": "boolean" },
        "computed": { "type": "boolean" },
        "formula": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "basis_enum": {
      "type": "string",
      "enum": ["handbook_range", "typical", "vendor_datasheet", "minimum", "design_allowable", "estimate"]
    },

    "rich_datum": {
      "type": "object",
      "required": ["value"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "source_id": { "type": "string" },
        "condition": { "type": "string" },
        "basis": { "$ref": "#/$defs/basis_enum" },
        "notes": { "type": ["string", "null"] }
      }
    },

    "property_value": {
      "description": "A property value: either a bare number (scalar shorthand) or a rich datum object.",
      "oneOf": [
        { "type": "number" },
        { "$ref": "#/$defs/rich_datum" }
      ]
    },

    "nullable_property_value": {
      "description": "A property value that may be null (unknown).",
      "oneOf": [
        { "type": "number" },
        { "$ref": "#/$defs/rich_datum" },
        { "type": "null" }
      ]
    },

    "processability_entry": {
      "type": "object",
      "required": ["process", "rating"],
      "additionalProperties": false,
      "properties": {
        "process": { "type": "string" },
        "rating": {
          "type": "string",
          "enum": ["excellent", "good", "fair", "poor", "not_recommended"]
        },
        "notes": { "type": "string" }
      }
    },

    "material_record": {
      "type": "object",
      "required": ["id", "name", "family", "sub_family", "record_kind", "default_source_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9\\-]*$" },
        "name": { "type": "string" },
        "family": {
          "type": "string",
          "enum": ["metal", "polymer", "ceramic", "composite", "natural", "foam", "fabric", "gel"]
        },
        "sub_family": { "type": "string" },
        "record_kind": {
          "type": "string",
          "enum": ["bulk_material", "lamina", "laminate", "sandwich", "foam", "fabric", "product"]
        },
        "designation": { "type": "string" },
        "common_names": { "type": "array", "items": { "type": "string" } },
        "default_source_id": { "type": "string" },
        "condition": { "type": "string" },
        "notes": { "type": ["string", "null"] },
        "related_ids": { "type": "array", "items": { "type": "string" } },

        "density": { "$ref": "#/$defs/nullable_property_value" },
        "youngs_modulus": { "$ref": "#/$defs/nullable_property_value" },
        "shear_modulus": { "$ref": "#/$defs/nullable_property_value" },
        "poissons_ratio": { "$ref": "#/$defs/nullable_property_value" },
        "yield_strength": { "$ref": "#/$defs/nullable_property_value" },
        "tensile_strength": { "$ref": "#/$defs/nullable_property_value" },
        "compressive_strength": { "$ref": "#/$defs/nullable_property_value" },
        "flexural_strength": { "$ref": "#/$defs/nullable_property_value" },
        "flexural_modulus": { "$ref": "#/$defs/nullable_property_value" },
        "elongation_at_break": { "$ref": "#/$defs/nullable_property_value" },
        "fracture_toughness": { "$ref": "#/$defs/nullable_property_value" },
        "fatigue_endurance_limit": { "$ref": "#/$defs/nullable_property_value" },
        "hardness_vickers": { "$ref": "#/$defs/nullable_property_value" },
        "hardness_shore_a": { "$ref": "#/$defs/nullable_property_value" },
        "hardness_shore_d": { "$ref": "#/$defs/nullable_property_value" },
        "impact_strength_izod": { "$ref": "#/$defs/nullable_property_value" },

        "youngs_modulus_transverse": { "$ref": "#/$defs/nullable_property_value" },
        "youngs_modulus_shear_12": { "$ref": "#/$defs/nullable_property_value" },
        "tensile_strength_transverse": { "$ref": "#/$defs/nullable_property_value" },
        "shear_strength_12": { "$ref": "#/$defs/nullable_property_value" },
        "cte_transverse": { "$ref": "#/$defs/nullable_property_value" },

        "thermal_conductivity": { "$ref": "#/$defs/nullable_property_value" },
        "specific_heat": { "$ref": "#/$defs/nullable_property_value" },
        "cte": { "$ref": "#/$defs/nullable_property_value" },
        "max_service_temp": { "$ref": "#/$defs/nullable_property_value" },
        "min_service_temp": { "$ref": "#/$defs/nullable_property_value" },
        "melting_point": { "$ref": "#/$defs/nullable_property_value" },
        "glass_transition_temp": { "$ref": "#/$defs/nullable_property_value" },
        "hdt_at_1_8mpa": { "$ref": "#/$defs/nullable_property_value" },
        "flammability_rating": { "type": ["string", "null"] },

        "electrical_resistivity": { "$ref": "#/$defs/nullable_property_value" },
        "dielectric_constant": { "$ref": "#/$defs/nullable_property_value" },
        "dielectric_strength": { "$ref": "#/$defs/nullable_property_value" },

        "price_per_kg": { "$ref": "#/$defs/nullable_property_value" },
        "embodied_energy": { "$ref": "#/$defs/nullable_property_value" },
        "co2_footprint": { "$ref": "#/$defs/nullable_property_value" },
        "recyclability": { "type": ["string", "null"], "enum": ["excellent", "good", "limited", "none", null] },
        "rohs_compliant": { "type": ["boolean", "null"] },

        "water_absorption_24h": { "$ref": "#/$defs/nullable_property_value" },
        "moisture_absorption_equilibrium": { "$ref": "#/$defs/nullable_property_value" },
        "uv_resistance": { "type": ["string", "null"], "enum": ["excellent", "good", "fair", "poor", null] },
        "chemical_resistance_acids": { "type": ["string", "null"], "enum": ["excellent", "good", "fair", "poor", null] },
        "chemical_resistance_bases": { "type": ["string", "null"], "enum": ["excellent", "good", "fair", "poor", null] },
        "chemical_resistance_solvents": { "type": ["string", "null"], "enum": ["excellent", "good", "fair", "poor", null] },

        "fiber_volume_fraction": { "$ref": "#/$defs/nullable_property_value" },
        "fiber_material_id": { "type": ["string", "null"] },
        "matrix_material_id": { "type": ["string", "null"] },
        "ply_thickness": { "$ref": "#/$defs/nullable_property_value" },

        "relative_density": { "$ref": "#/$defs/nullable_property_value" },
        "cell_type": { "type": ["string", "null"], "enum": ["open", "closed", "mixed", null] },
        "base_material_id": { "type": ["string", "null"] },

        "areal_density": { "$ref": "#/$defs/nullable_property_value" },
        "weave_type": { "type": ["string", "null"], "enum": ["plain", "twill", "satin", "unidirectional", "nonwoven", null] },

        "processability": {
          "type": "array",
          "items": { "$ref": "#/$defs/processability_entry" }
        }
      }
    }
  }
}
