{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparent.tools/data/materials/staging/extracted_datum.schema.json",
  "title": "Materials Ingest Extracted Datum",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_material_key",
    "property_id",
    "source_id",
    "artifact_id",
    "review_status"
  ],
  "properties": {
    "candidate_material_key": {
      "type": "string"
    },
    "property_id": {
      "type": "string"
    },
    "value": {
      "type": ["number", "null"]
    },
    "min": {
      "type": ["number", "null"]
    },
    "max": {
      "type": ["number", "null"]
    },
    "raw_text": {
      "type": ["string", "null"]
    },
    "raw_units": {
      "type": ["string", "null"]
    },
    "normalized_units": {
      "type": ["string", "null"]
    },
    "basis": {
      "type": ["string", "null"]
    },
    "test_standard": {
      "type": ["string", "null"]
    },
    "temperature": {
      "type": ["string", "null"]
    },
    "humidity": {
      "type": ["string", "null"]
    },
    "moisture_state": {
      "type": ["string", "null"]
    },
    "orientation": {
      "type": ["string", "null"]
    },
    "processing_state": {
      "type": ["string", "null"]
    },
    "thickness_or_form": {
      "type": ["string", "null"]
    },
    "parser_confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "source_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "page_or_section": {
      "type": ["string", "null"]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "new",
        "parsed",
        "needs_review",
        "accepted",
        "accepted_with_edits",
        "rejected",
        "superseded"
      ]
    },
    "review_notes": {
      "type": ["string", "null"]
    }
  }
}
