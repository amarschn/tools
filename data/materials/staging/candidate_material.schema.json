{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparent.tools/data/materials/staging/candidate_material.schema.json",
  "title": "Materials Ingest Candidate Material",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_material_key",
    "source_id",
    "raw_title"
  ],
  "properties": {
    "candidate_material_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-]*$"
    },
    "source_id": {
      "type": "string"
    },
    "manufacturer": {
      "type": ["string", "null"]
    },
    "trade_name": {
      "type": ["string", "null"]
    },
    "grade_or_designation": {
      "type": ["string", "null"]
    },
    "generic_family_guess": {
      "type": ["string", "null"]
    },
    "record_kind_guess": {
      "type": ["string", "null"]
    },
    "form_guess": {
      "type": ["string", "null"]
    },
    "raw_title": {
      "type": "string"
    },
    "raw_description": {
      "type": ["string", "null"]
    },
    "related_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
