{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparent.tools/data/materials/staging/artifact.schema.json",
  "title": "Materials Ingest Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "source_id",
    "artifact_type",
    "original_url",
    "retrieved_at",
    "content_hash",
    "local_path"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-]*$"
    },
    "source_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["html", "pdf", "csv", "tsv", "xlsx", "json"]
    },
    "original_url": {
      "type": "string"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "http_status": {
      "type": ["integer", "null"]
    },
    "content_hash": {
      "type": "string"
    },
    "local_path": {
      "type": "string"
    },
    "content_type": {
      "type": ["string", "null"]
    },
    "discovery_context": {
      "type": ["string", "null"]
    },
    "parent_artifact_id": {
      "type": ["string", "null"]
    }
  }
}
