{
    "name": "Cooldown to Service Temperature",
    "description": "Source has been driven to 90 °C. Power is now zero; how long until the part is safe to handle (40 °C)? Pulse profile with zero pulse power is used so the simulator runs from a hot starting condition through a pure decay. Answers \"How much cooldown time do I need?\"",
    "model": {
        "time": {
            "duration_s": 1800.0,
            "initial_temperature_c": 90.0,
            "cooldown_target_c": 40.0
        },
        "profile": {
            "type": "pulse",
            "pulse_power_w": 0.0,
            "pulse_duration_s": 0.1,
            "cooldown_power_w": 0.0
        },
        "network": {
            "nodes": [
                {
                    "id": "source",
                    "label": "Source (preheated)",
                    "kind": "dynamic",
                    "capacitance_j_per_k": 12.0
                },
                {
                    "id": "sink",
                    "label": "Heatsink (preheated)",
                    "kind": "dynamic",
                    "capacitance_j_per_k": 310.0
                },
                {
                    "id": "ambient",
                    "label": "Ambient",
                    "kind": "boundary",
                    "fixed_temperature_c": 25.0
                }
            ],
            "segments": [
                {
                    "id": "r_jc",
                    "label": "Source to sink",
                    "from_node_id": "source",
                    "to_node_id": "sink",
                    "resistance_k_per_w": 0.5
                },
                {
                    "id": "r_sa",
                    "label": "Sink to ambient",
                    "from_node_id": "sink",
                    "to_node_id": "ambient",
                    "resistance_k_per_w": 1.5
                }
            ],
            "heat_inputs": [{"node_id": "source", "profile_role": "primary"}]
        }
    },
    "expected_outputs": {
        "cooldown_time_to_target_s_is_finite": true,
        "final_temperature_c_max": 50.0
    },
    "provenance": {
        "source_type": "internal_baseline",
        "citation": "Slow tau = R_sa*C_sink ≈ 465 s; cooldown to 40 °C from 90 °C takes about 1.2 tau ≈ 560 s.",
        "date_created": "2026-05-03",
        "notes": "Use this to verify cooldown_time_to_target reporting and the pure-decay code path."
    },
    "validation_level": "self_baseline"
}
