{
    "name": "Continuous Step Load — IGBT on extruded sink",
    "description": "30 W continuous load on a 100x100 mm aluminum 6063 plate-fin sink with natural convection. Auto-extension expands the simulation window so the steady-state asymptote is visible. Answers \"How long can I run before I hit the temperature limit?\"",
    "model": {
        "time": {
            "duration_s": 300.0,
            "initial_temperature_c": 25.0,
            "cooldown_target_c": 40.0
        },
        "profile": {
            "type": "step",
            "power_w": 30.0
        },
        "network": {
            "nodes": [
                {
                    "id": "source",
                    "label": "IGBT junction",
                    "kind": "dynamic",
                    "capacitance_j_per_k": 12.0,
                    "max_temperature_c": 110.0
                },
                {
                    "id": "sink",
                    "label": "Extruded heatsink",
                    "kind": "dynamic",
                    "capacitance_j_per_k": 310.0
                },
                {
                    "id": "ambient",
                    "label": "Ambient",
                    "kind": "boundary",
                    "fixed_temperature_c": 25.0
                }
            ],
            "segments": [
                {
                    "id": "r_jc",
                    "label": "Junction-to-case + TIM",
                    "from_node_id": "source",
                    "to_node_id": "sink",
                    "resistance_k_per_w": 0.5
                },
                {
                    "id": "r_sa",
                    "label": "Sink to ambient",
                    "from_node_id": "sink",
                    "to_node_id": "ambient",
                    "resistance_k_per_w": 1.5
                }
            ],
            "heat_inputs": [{"node_id": "source", "profile_role": "primary"}]
        }
    },
    "expected_outputs": {
        "status_is": ["acceptable", "marginal"],
        "auto_extended_duration": true,
        "steady_state_temperature_c_max": 90.0,
        "peak_node_id": "source"
    },
    "provenance": {
        "source_type": "internal_baseline",
        "citation": "Standard IGBT-on-heatsink reference geometry. Asymptote = 25 + 30*(0.5+1.5) = 85 °C.",
        "date_created": "2026-05-03",
        "notes": "Demonstrates the 'continuous load, will it survive long-term' workflow."
    },
    "validation_level": "self_baseline"
}
