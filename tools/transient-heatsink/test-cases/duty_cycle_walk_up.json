{
    "name": "Duty Cycle Walk-Up Detection",
    "description": "Heavy 50% duty cycle whose mean-power asymptote sits above the 80 °C source limit. Verifies that the simulator flags the limit crossing and reports an unacceptable status with cycle-by-cycle walk-up.",
    "model": {
        "time": {
            "duration_s": 200.0,
            "initial_temperature_c": 25.0
        },
        "profile": {
            "type": "duty_cycle",
            "on_power_w": 120.0,
            "on_time_s": 5.0,
            "off_power_w": 0.0,
            "off_time_s": 5.0
        },
        "network": {
            "nodes": [
                {
                    "id": "lump",
                    "label": "Lumped source+sink",
                    "kind": "dynamic",
                    "capacitance_j_per_k": 50.0,
                    "max_temperature_c": 80.0
                },
                {
                    "id": "ambient",
                    "label": "Ambient",
                    "kind": "boundary",
                    "fixed_temperature_c": 25.0
                }
            ],
            "segments": [
                {
                    "id": "r_la",
                    "label": "Lump → ambient",
                    "from_node_id": "lump",
                    "to_node_id": "ambient",
                    "resistance_k_per_w": 1.0
                }
            ],
            "heat_inputs": [{"node_id": "lump", "profile_role": "primary"}]
        }
    },
    "expected_outputs": {
        "status_is": ["unacceptable", "marginal"],
        "time_to_limit_s_is_finite": true,
        "cycle_count_min": 10
    },
    "provenance": {
        "source_type": "internal_regression",
        "citation": "Internal regression baseline captured 2026-04-25 to validate cyclic walk-up detection.",
        "date_created": "2026-04-25",
        "notes": "Mean power = 60 W; with R = 1 K/W, asymptotic mean T = 25 + 60 = 85 °C, well above the 80 °C limit."
    },
    "validation_level": "self_baseline"
}
